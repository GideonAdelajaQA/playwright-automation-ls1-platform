# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LS1 app config
LS1_BASE_URL=https://your-ls1-app.com
LS1_USERNAME=your-username
LS1_PASSWORD=your-password

# Role to explore as (affects which flows are visible)
# Options: distributor_manager | sales_rep | sub_distributor | admin
EXPLORE_AS_ROLE=distributor_manager

# Explorer behaviour
MAX_PAGES=20              # Stop after visiting this many unique pages
MAX_DEPTH=4               # Max click depth from login
SCREENSHOT_ON_EACH=true   # Capture screenshot at every page
HEADLESS=true             # false = watch the browser navigate live
